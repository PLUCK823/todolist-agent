# ==========================================
# Agent TodoList 环境变量模板
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ==========================================

# === 数据库 (PostgreSQL) ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=todolist
POSTGRES_PASSWORD=changeme
POSTGRES_DB=todolist

# === 缓存 (Redis) ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# === 后端服务 ===
BACKEND_PORT=8080
BACKEND_CORS_ORIGINS=http://localhost:3000

# === 服务端认证 ===
# 必填：为每个部署生成独立随机值，例如：openssl rand -base64 48
# 不要复用示例值、API Key 或数据库密码，也不要提交填好的 .env。
AUTH_JWT_SECRET=
AUTH_ACCESS_COOKIE=todolist_access
AUTH_REFRESH_COOKIE=todolist_refresh
AUTH_ALLOWED_ORIGINS=http://localhost:3000
# HTTPS 部署必须设为 true；仅本机 HTTP 开发使用 false。Domain 留空即 host-only Cookie。
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=

# === Agent 服务 ===
AGENT_SERVICE_PORT=8000
BACKEND_URL=http://localhost:8080/api

# LLM 配置（密钥仅写入本地 .env，不要提交）
# provider: openai | anthropic | google (gemini) | deepseek | openai-compatible
LLM_PROVIDER=openai
LLM_API_KEY=replace-with-provider-api-key
LLM_MODEL=gpt-4o
LLM_BASE_URL=
LLM_TEMPERATURE=0.1

# === 前端 ===
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8000

# === 日志 ===
LOG_LEVEL=debug                  # debug | info | warn | error
